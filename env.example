# ============================================================
#  octo-chainsaw — .env.example
#
#  Copy this file to .env for Vite client/SSR variables.
#  For Cloudflare Worker secrets, also create .dev.vars
#  (see the .dev.vars.example section in the audit doc).
#
#  All four variables below are REQUIRED for a basic run.
# ============================================================


# ── SUPABASE (client-side, safe to expose) ──────────────────
# Obtain from: Supabase Dashboard → Project Settings → API

# Your project's public REST/WebSocket URL
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon/public key (JWT) — safe for browser use; does NOT bypass RLS
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<sig>


# ── SUPABASE SERVICE ROLE (server-side / Worker — KEEP SECRET) ──
# Obtain from: Supabase Dashboard → Project Settings → API
# Local dev : add to .dev.vars (not this file)
# Production: wrangler secret put SUPABASE_SERVICE_ROLE_KEY
#
# NEVER commit this key or expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.<payload>.<sig>


# ── OPENAI (server-side / Worker — KEEP SECRET) ─────────────
# Obtain from: https://platform.openai.com/api-keys
# Local dev : add to .dev.vars (not this file)
# Production: wrangler secret put OPENAI_API_KEY
#
# Used for Chat Completions (map generation) and Embeddings (RAG).
# NEVER commit this key or expose it to the browser.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

SUPABASE_PUBLISHABLE_KEY=sb_publishable_RyIHePHmdmLnQKISSFE2Yg_f7pnruVL